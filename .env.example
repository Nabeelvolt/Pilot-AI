# ── LLM (unchanged — already free) ───────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key
GEMINI_API_KEY=your_gemini_key
PRIMARY_LLM=llama-3.3-70b-versatile
FALLBACK_LLM=gemini-1.5-flash

# ── Jina AI Embeddings (free — get at jina.ai, no credit card) ───────────────
JINA_API_KEY=jina_your_key_here
JINA_EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIM=1024

# ── Supabase (free — create project at supabase.com, choose London region) ───
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_DB_URL=postgresql://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres
SUPABASE_STORAGE_BUCKET=pilot-ai-documents

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app
ENVIRONMENT=production
